{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodev.local/schemas/v2/plugin.schema.json",
  "title": "AutoDev v2 plugin.yaml",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "hostApi", "runtime", "extensionPoints"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["1", "1.0"] },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "hostApi": { "type": "string" },
    "runtime": {
      "type": "object",
      "required": ["loader", "entrypoint"],
      "properties": {
        "loader": { "type": "string", "enum": ["in-process", "subprocess", "wasm"] },
        "entrypoint": { "type": "string" },
        "isolation": { "type": "string" },
        "resources": { "type": "object" }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostApi": { "type": "array", "items": { "type": "string" } },
        "network": {
          "type": "object",
          "properties": {
            "egress": { "type": "array", "items": { "type": "string" } }
          }
        },
        "filesystem": {
          "type": "object",
          "properties": {
            "read": { "type": "array", "items": { "type": "string" } },
            "write": { "type": "array", "items": { "type": "string" } }
          }
        },
        "exec": {
          "type": "object",
          "properties": {
            "commands": { "type": "array", "items": { "type": "string" } }
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "required": { "type": "boolean" }
                }
              }
            ]
          }
        },
        "events": {
          "type": "object",
          "properties": {
            "publish": { "type": "array", "items": { "type": "string" } },
            "subscribe": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "extensionPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "id", "contract"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "agent",
              "skill",
              "tool",
              "reasoning",
              "router",
              "selector",
              "evaluator",
              "context_provider",
              "retriever",
              "validation_gate",
              "ui_panel",
              "event_handler"
            ]
          },
          "id": { "type": "string" },
          "contract": { "type": "string" },
          "entrypoint": { "type": "string" },
          "manifest": { "type": "string" }
        }
      }
    }
  }
}
