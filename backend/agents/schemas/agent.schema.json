{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodev.local/schemas/v2/agent.schema.json",
  "title": "AutoDev Agent Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "kind", "id", "version", "hostApi", "capabilities", "io", "entrypoint"],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "kind": { "const": "Agent" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$" },
    "hostApi": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "enum": [
              "code.implementation",
              "code.refactor",
              "planning.decompose",
              "security.review",
              "validation.plan"
            ]
          },
          "version": { "type": "string" },
          "level": { "enum": ["primary", "secondary"] }
        }
      }
    },
    "io": {
      "type": "object",
      "required": ["contract", "contractVersion", "input", "output"],
      "properties": {
        "contract": { "type": "string" },
        "contractVersion": { "type": "string" },
        "input": { "type": "object" },
        "output": { "type": "object" },
        "onInvalidOutput": { "enum": ["repair-then-fail", "fail", "passthrough"] }
      }
    },
    "budgets": {
      "type": "object",
      "properties": {
        "tokens": {
          "type": "object",
          "properties": {
            "input": { "type": "integer", "minimum": 1 },
            "output": { "type": "integer", "minimum": 1 }
          }
        },
        "costUsd": { "type": "number", "exclusiveMinimum": 0 },
        "wallClockSeconds": { "type": "integer", "minimum": 1 },
        "maxSteps": { "type": "integer", "minimum": 1 },
        "maxToolCalls": { "type": "integer", "minimum": 1 },
        "onExceeded": { "enum": ["fail-closed", "degrade", "ask-human"] }
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network": { "enum": ["none", "declared"] },
        "tools": { "type": "array" },
        "skills": { "type": "array" }
      }
    },
    "entrypoint": {
      "type": "object",
      "required": ["runtime", "ref"],
      "properties": {
        "runtime": { "const": "python" },
        "ref": { "type": "string" }
      }
    }
  }
}
