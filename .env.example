# Backend runtime
DATABASE_URL=sqlite:///./autodev.db
LLM_PROVIDER=stub
# Set LLM_PROVIDER=openai to enable a real agent API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.2
# Development only: set to false when the LLM endpoint uses a self-signed
# certificate (e.g. corporate proxy). Disabling TLS verification exposes the API
# key to man-in-the-middle attacks — never do this in production.
OPENAI_VERIFY_SSL=true
UVICORN_RELOAD=true
AUTODEV_PROJECT_ROOT=
AUTODEV_CONFIG_PATH=

# API authentication (opt-in). Leave empty to keep the API open for local
# development. Set a strong random token to require
# `Authorization: Bearer <token>` on every request (except /health and docs).
AUTODEV_API_TOKEN=

# Bind address / port for sandbox/run_orchestrator.py (defaults are loopback).
# Set AUTODEV_HOST=0.0.0.0 only behind a trusted proxy or with a token set.
AUTODEV_HOST=127.0.0.1
AUTODEV_PORT=8000

# Validation sandbox (all disabled by default).
# AUTODEV_ENABLE_SANDBOX=1        # enable command execution
# AUTODEV_SANDBOX_ALLOW_LOCAL=1   # allow UNSANDBOXED host execution when Docker is absent
# AUTODEV_SANDBOX_DOCKER_NETWORK=none  # container network mode (default: none)

# Frontend runtime
NEXT_PUBLIC_API_URL=http://localhost:8000
